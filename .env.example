# =============================================================================
# Variáveis de ambiente — copie para .env.local e preencha.
# NUNCA commite .env.local (está no .gitignore). Ver PLANO.md §7.
# =============================================================================

# --- Público (exposto ao browser) — apenas NEXT_PUBLIC_* -----------------------
# URL do projeto Supabase (ex.: https://xxxx.supabase.co). Local: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=
# Chave anônima (publishable). É pública por design; a segurança vem da RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# URL pública do app (opcional; usada em links absolutos/push).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# DSN público do Sentry (opcional). Sem ele, a observabilidade fica inerte.
NEXT_PUBLIC_SENTRY_DSN=

# --- Secreto (SOMENTE servidor) — jamais com prefixo NEXT_PUBLIC_ --------------
# service_role: IGNORA a RLS. Só no servidor. Vazamento = comprometimento total.
SUPABASE_SERVICE_ROLE_KEY=
# Web Push (VAPID). Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:development@espacocinthiafranca.com.br
# Sentry (servidor) — opcional.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Build / CI ----------------------------------------------------------------
# "true" pula a validação de env (usado no build de CI sem segredos).
# SKIP_ENV_VALIDATION=true
